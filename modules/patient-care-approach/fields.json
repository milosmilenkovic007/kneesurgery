{
  "key": "layout_hj_patient_care_approach",
  "name": "patient_care_approach",
  "label": "Patient Care Approach",
  "display": "block",
  "sub_fields": [
    {
      "key": "field_hj_pca_anchor_id",
      "label": "Anchor ID",
      "name": "anchor_id",
      "type": "text",
      "instructions": "Optional section anchor, e.g. patient-care-approach or #patient-care-approach.",
      "placeholder": "patient-care-approach"
    },
    {
      "key": "field_hj_pca_title",
      "label": "Title",
      "name": "title",
      "type": "text",
      "required": 1,
      "default_value": "Healing Journey® Approach To"
    },
    {
      "key": "field_hj_pca_title_accent",
      "label": "Title Accent",
      "name": "title_accent",
      "type": "text",
      "default_value": "Patient Care"
    },
    {
      "key": "field_hj_pca_rows",
      "label": "Rows",
      "name": "rows",
      "type": "repeater",
      "layout": "block",
      "button_label": "Add Row",
      "min": 1,
      "sub_fields": [
        {
          "key": "field_hj_pca_row_title",
          "label": "Left Title",
          "name": "title",
          "type": "text",
          "required": 1,
          "wrapper": {
            "width": "35"
          }
        },
        {
          "key": "field_hj_pca_row_content",
          "label": "Right Content",
          "name": "content",
          "type": "wysiwyg",
          "tabs": "visual,text",
          "toolbar": "basic",
          "media_upload": 0,
          "required": 1,
          "wrapper": {
            "width": "65"
          }
        }
      ]
    }
  ]
}