{
  "key": "layout_hj_pricelist_accordion",
  "name": "pricelist_accordion",
  "label": "Pricelist – Accordion",
  "display": "block",
  "sub_fields": [
    { "key": "field_hj_pa_title", "label": "Module Title", "name": "module_title", "type": "text", "placeholder": "Price List" },
    { "key": "field_hj_pa_subtitle", "label": "Module Subtitle", "name": "module_subtitle", "type": "text", "placeholder": "Optional subtitle under the main title" },
    { "key": "field_hj_pa_subtitle_left", "label": "Left Column (HTML)", "name": "module_subtitle_left", "type": "wysiwyg", "tabs": "visual,text", "toolbar": "basic", "media_upload": 0, "wrapper": {"width": "50"}, "instructions": "Left column content (supports HTML). If both left and right are filled, subtitle above will be ignored." },
    { "key": "field_hj_pa_subtitle_right", "label": "Right Column (HTML)", "name": "module_subtitle_right", "type": "wysiwyg", "tabs": "visual,text", "toolbar": "basic", "media_upload": 0, "wrapper": {"width": "50"}, "instructions": "Right column content (supports HTML). If both left and right are filled, subtitle above will be ignored." },
    { "key": "field_hj_pa_currency", "label": "Currency Symbol", "name": "currency", "type": "text", "default_value": "€", "wrapper": {"width": "20"} },
    { "key": "field_hj_pa_sections", "label": "Sections", "name": "sections", "type": "repeater", "button_label": "Add Section", "layout": "row", "collapsed": "field_hj_pa_section_title", "sub_fields": [
      { "key": "field_hj_pa_section_title", "label": "Section Title", "name": "section_title", "type": "text", "required": 1 },
      { "key": "field_hj_pa_section_intro", "label": "Section Intro", "name": "section_intro", "type": "text", "instructions": "Shown below tab title and above items/package." },
      { "key": "field_hj_pa_package_view", "label": "Package View", "name": "package_view", "type": "true_false", "ui": 1, "message": "Use custom package content instead of items/prices" },
      { "key": "field_hj_pa_package_content_mode", "label": "Package Content Type", "name": "package_content_mode", "type": "radio", "layout": "horizontal", "choices": {"template": "Structured Template", "wysiwyg": "Visual Editor", "html": "HTML"}, "default_value": "template",
        "conditional_logic": [ [ { "field": "field_hj_pa_package_view", "operator": "==", "value": "1" } ] ]
      },
      { "key": "field_hj_pa_pkg_group", "label": "Package Template Content", "name": "package_template", "type": "group", "layout": "block",
        "conditional_logic": [ [ { "field": "field_hj_pa_package_view", "operator": "==", "value": "1" }, { "field": "field_hj_pa_package_content_mode", "operator": "==", "value": "template" } ] ],
        "sub_fields": [
          { "key": "field_hj_pa_pkg_slug", "label": "Template Slug (optional)", "name": "slug", "type": "text", "placeholder": "all-on-4", "wrapper": {"width": "30"}, "instructions": "Used as BEM modifier class hj-package--{slug}" },
          { "key": "field_hj_pa_pkg_title", "label": "Package Title", "name": "title", "type": "text", "wrapper": {"width": "70"} },
          { "key": "field_hj_pa_pkg_subtitle", "label": "Package Subtitle", "name": "subtitle", "type": "textarea", "rows": 3 },

          { "key": "field_hj_pa_pkg_highlights", "label": "Package Includes", "name": "highlights", "type": "repeater", "button_label": "Add Include", "layout": "table", "sub_fields": [
            { "key": "field_hj_pa_pkg_highlight_text", "label": "Text", "name": "text", "type": "textarea", "rows": 2 }
          ]},

          { "key": "field_hj_pa_pkg_price_group", "label": "Price Block", "name": "price", "type": "group", "layout": "block", "sub_fields": [
            { "key": "field_hj_pa_pkg_price_title", "label": "Title", "name": "title", "type": "text", "default_value": "Final package price:" },
            { "key": "field_hj_pa_pkg_price_amount", "label": "Amount", "name": "amount", "type": "text", "wrapper": {"width": "30"} },
            { "key": "field_hj_pa_pkg_price_currency", "label": "Currency", "name": "currency", "type": "text", "wrapper": {"width": "20"}, "default_value": "GBP" },
            { "key": "field_hj_pa_pkg_price_note", "label": "Note", "name": "note", "type": "textarea", "rows": 3 }
          ]},

          { "key": "field_hj_pa_pkg_cta_group", "label": "Call to Action Button", "name": "cta_button", "type": "group", "layout": "block", "sub_fields": [
            { "key": "field_hj_pa_pkg_cta_text", "label": "Button Text", "name": "text", "type": "text", "default_value": "Book Now", "wrapper": {"width": "50"} },
            { "key": "field_hj_pa_pkg_cta_url", "label": "Button URL", "name": "url", "type": "text", "default_value": "#candidate", "wrapper": {"width": "50"}, "instructions": "Use #candidate to open the candidate form" }
          ]}
        ]
      },
      { "key": "field_hj_pa_package_content", "label": "Package Content (Visual)", "name": "package_content", "type": "wysiwyg", "tabs": "visual", "toolbar": "full", "media_upload": 0, "instructions": "Shown instead of items/prices when Package View is enabled.",
        "conditional_logic": [ [ { "field": "field_hj_pa_package_view", "operator": "==", "value": "1" }, { "field": "field_hj_pa_package_content_mode", "operator": "==", "value": "wysiwyg" } ] ]
      },
      { "key": "field_hj_pa_package_content_html", "label": "Package Content (HTML)", "name": "package_content_html", "type": "textarea", "rows": 12, "new_lines": "",
        "instructions": "Paste or write raw HTML. It will be output as-is.",
        "conditional_logic": [ [ { "field": "field_hj_pa_package_view", "operator": "==", "value": "1" }, { "field": "field_hj_pa_package_content_mode", "operator": "==", "value": "html" } ] ]
      },
      { "key": "field_hj_pa_items", "label": "Items", "name": "items", "type": "repeater", "button_label": "Add Item", "layout": "table", "collapsed": "field_hj_pa_item_title", "conditional_logic": [ [ { "field": "field_hj_pa_package_view", "operator": "!=", "value": "1" } ] ], "sub_fields": [
        { "key": "field_hj_pa_item_title", "label": "Title", "name": "item_title", "type": "text", "required": 1 },
        { "key": "field_hj_pa_item_price", "label": "Price", "name": "item_price", "type": "text", "wrapper": {"width": "20"} },
        { "key": "field_hj_pa_item_desc", "label": "Short Description", "name": "item_desc", "type": "textarea", "rows": 2 }
      ]}
    ]}
  ]
}